{
  "name": "YouTube zu E-Book (Korrigierte Reihenfolge)",
  "nodes": [
    {
      "type": "n8n-nodes-base.executeCommand",
      "name": "yt-dlp_Extract",
      "parameters": {
        "command": "yt-dlp --write-subs --sub-langs en --skip-download --output \"/tmp/{{$node.youtube_id}}.%(ext)s\" \"{{$node.youtube_url}}\"",
        "continueOnFail": false
      }
    },
    {
      "type": "n8n-nodes-base.readBinaryFile",
      "name": "SRT_zu_Text",
      "parameters": {
        "filePath": "=/tmp/{{$node.youtube_id}}.en.srt",
        "destinationProperty": "Transkript_Roh"
      }
    },
    {
      "type": "n8n-nodes-base.openAi",
      "name": "OpenRouter_Struktur",
      "parameters": {
        "apiEndpoint": "https://openrouter.ai/api/v1/chat/completions",
        "apiKey": "={{ $env.OPENROUTER_API_KEY }}",
        "model": "anthropic/claude-3.5-sonnet",
        "prompt": "Analysiere dieses Transkript und erstelle eine E-Book-Struktur mit 5-7 Kapiteln. JSON: {\"ebook_titel\": \"...\", \"ebook_untertitel\": \"...\", \"kapitel\": [{\"titel\": \"...\", \"inhalt_kurz\": \"...\"}]}. Transkript: {{$node.Transkript_Roh}}",
        "options": {
          "responseFormat": "json"
        }
      }
    },
    {
      "type": "n8n-nodes-base.openAi",
      "name": "OpenRouter_Uebersetzung",
      "parameters": {
        "apiEndpoint": "https://openrouter.ai/api/v1/chat/completions",
        "apiKey": "={{ $env.OPENROUTER_API_KEY }}",
        "model": "anthropic/claude-3.5-sonnet",
        "prompt": "Übersetze ins Deutsche. JSON: {{$node.json}}",
        "options": {
          "responseFormat": "json"
        }
      }
    },
    {
      "type": "n8n-nodes-base.httpRequest",
      "name": "GitHub_Markdown_Push",
      "parameters": {
        "method": "PUT",
        "url": "https://api.github.com/repos/{{$env.GITHUB_USER}}/{{$env.GITHUB_REPO}}/contents/n8n-ebooks/{{$node.youtube_id}}.md",
        "headers": {
          "Authorization": "token {{$env.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        },
        "body": {
          "message": "E-Book: {{$node.json.ebook_titel}}",
          "content": "={{ $base64($node.markdown_content) }}"
        }
      }
    },
    {
      "type": "n8n-nodes-base.telegram",
      "name": "Telegram_Review_Anfrage",
      "parameters": {
        "botToken": "={{ $env.TELEGRAM_BOT_TOKEN }}",
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "📚 *E-Book zur Review: {{$node.json.ebook_titel}}*\n\n🔗 GitHub: https://github.com/{{$env.GITHUB_USER}}/{{$env.GITHUB_REPO}}/blob/main/n8n-ebooks/{{$node.youtube_id}}.md\n\n[✅ Freigeben für Cover + PDF]({{$node.webhook_url}}?action=approve)",
        "options": {
          "reply_markup": {
            "inline_keyboard": [
              [
                {
                  "text": "📝 Bearbeiten (GitHub)",
                  "url": "https://github.com/{{$env.GITHUB_USER}}/{{$env.GITHUB_REPO}}/edit/main/n8n-ebooks/{{$node.youtube_id}}.md"
                }
              ],
              [
                {
                  "text": "✅ Freigeben",
                  "callback_data": "approve"
                }
              ]
            ]
          }
        }
      }
    },
    {
      "type": "n8n-nodes-base.webhook",
      "name": "Telegram_Antwort",
      "parameters": {
        "httpMethod": "POST",
        "responseMode": "onReceived",
        "path": "telegram-callback"
      }
    },
    {
      "type": "n8n-nodes-base.if",
      "name": "Pruefe_Freigabe",
      "parameters": {
        "conditions": {
          "string": "={{ $node.webhook_received.callback_data }}",
          "equal": "approve"
        }
      }
    },
    {
      "type": "n8n-nodes-base.openAi",
      "name": "OpenRouter_Cover",
      "parameters": {
        "apiEndpoint": "https://openrouter.ai/api/v1/images/generations",
        "apiKey": "={{ $env.OPENROUTER_API_KEY }}",
        "model": "openai/dall-e-3",
        "prompt": "E-Book Cover: {{$node.json.ebook_titel}}. {{$node.json.ebook_untertitel}}. Professionell, modern, minimalistisch. 1024x1792. Kein Text im Bild.",
        "size": "1024x1792",
        "responseType": "file",
        "outputProperty": "Cover_Pfad"
      }
    },
    {
      "type": "n8n-nodes-base.httpRequest",
      "name": "GitHub_Cover_Push",
      "parameters": {
        "method": "PUT",
        "url": "https://api.github.com/repos/{{$env.GITHUB_USER}}/{{$env.GITHUB_REPO}}/contents/n8n-ebooks/{{$node.youtube_id}}.png",
        "headers": {
          "Authorization": "token {{$env.GITHUB_TOKEN}}",
          "Content-Type": "application/json"
        },
        "body": {
          "message": "Cover: {{$node.json.ebook_titel}}",
          "content": "={{ $base64($node.Cover_Pfad) }}"
        }
      }
    },
    {
      "type": "n8n-nodes-base.executeCommand",
      "name": "Pandoc_PDF",
      "parameters": {
        "command": "pandoc /tmp/{{$node.youtube_id}}.md -o /output/{{$node.youtube_id}}.pdf --pdf-engine=xelatex --toc",
        "executeOnce": false
      }
    },
    {
      "type": "n8n-nodes-base.telegram",
      "name": "Fertig_Benachrichtigung",
      "parameters": {
        "botToken": "={{ $env.TELEGRAM_BOT_TOKEN }}",
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "✅ E-Book fertig: {{$node.json.ebook_titel}}\n\n🎨 Cover: https://github.com/{{$env.GITHUB_USER}}/{{$env.GITHUB_REPO}}/blob/main/n8n-ebooks/{{$node.youtube_id}}.png\n\n📄 PDF: /output/{{$node.youtube_id}}.pdf"
      }
    }
  ],
  "connections": {
    "yt-dlp_Extract": {
      "main": [
        [
          {
            "node": "SRT_zu_Text",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "SRT_zu_Text": {
      "main": [
        [
          {
            "node": "OpenRouter_Struktur",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenRouter_Struktur": {
      "main": [
        [
          {
            "node": "OpenRouter_Uebersetzung",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenRouter_Uebersetzung": {
      "main": [
        [
          {
            "node": "GitHub_Markdown_Push",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GitHub_Markdown_Push": {
      "main": [
        [
          {
            "node": "Telegram_Review_Anfrage",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Telegram_Review_Anfrage": {
      "main": [
        [
          {
            "node": "Telegram_Antwort",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Telegram_Antwort": {
      "main": [
        [
          {
            "node": "Pruefe_Freigabe",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Pruefe_Freigabe": {
      "true": [
        [
          {
            "node": "OpenRouter_Cover",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenRouter_Cover": {
      "main": [
        [
          {
            "node": "GitHub_Cover_Push",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "GitHub_Cover_Push": {
      "main": [
        [
          {
            "node": "Pandoc_PDF",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Pandoc_PDF": {
      "main": [
        [
          {
            "node": "Fertig_Benachrichtigung",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
